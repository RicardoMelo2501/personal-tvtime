# Copie este arquivo para ".env" e preencha com os valores reais.
# O ".env" nunca deve ser commitado (já está no .gitignore).
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-chave-anon-publica

# API Key da TheTVDB (thetvdb.com/dashboard/account/apikey).
# É usada no navegador para fazer login e obter um bearer token (válido por 1 mês),
# que por sua vez busca capas/artes de séries e filmes.
TVDB_API_KEY=sua-api-key-da-thetvdb
